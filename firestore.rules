rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidOrder(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.phoneNumber is string && data.phoneNumber.size() <= 20 &&
             data.totalPrice is number &&
             data.status in ['pending', 'preparing', 'completed', 'cancelled'] &&
             data.createdAt is number &&
             data.items is list && data.items.size() > 0;
    }

    match /orders/{orderId} {
      // Allowing public creation of orders
      allow create: if isValidId(orderId) && isValidOrder(incoming()) && 
                    incoming().status == 'pending';
      
      // Only authenticated users (seller) can read and update status
      // Note: For a truly secure multi-user app, we'd check against an admin list, 
      // but for this simple app, we'll allow any authenticated account (the owner)
      allow read, list: if isSignedIn();
      
      allow update: if isSignedIn() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().customerName == existing().customerName &&
        incoming().id == existing().id
      );
      
      allow delete: if isSignedIn();
    }
  }
}
